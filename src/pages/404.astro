---
// Bu sayfa dinamik olarak oluşturulur - 404 durumunda geri dönüş
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Sayfa Bulunamadı – 404"
  description="Aradığınız sayfa bulunamadı. EC POWER ana sayfasına dönün veya ürünlerimizi inceleyin."
  noindex={true}
>
  <main id="main-content" style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:120px 24px 60px;background:var(--bg-light);">
    <div style="text-align:center;max-width:600px;">
      <div style="font-family:'Space Grotesk',sans-serif;font-size:120px;font-weight:800;background:linear-gradient(135deg,#2563EB,#06B6D4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:24px;">404</div>
      <h1 style="font-size:clamp(24px,4vw,36px);color:var(--text-primary);margin-bottom:16px;">Sayfa Bulunamadı</h1>
      <p style="color:var(--text-secondary);font-size:18px;line-height:1.7;margin-bottom:40px;">
        Aradığınız sayfa taşınmış, silinmiş veya hiç var olmamış olabilir.
        EC POWER ana sayfasına dönün.
      </p>
      <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
        <a href="/" class="btn btn-primary btn-lg">Ana Sayfaya Dön</a>
        <a href="/products" class="btn btn-outline btn-lg">Ürünleri İncele</a>
        <a href="/contact" class="btn btn-outline btn-lg">İletişim</a>
      </div>
    </div>
  </main>
</Layout>
