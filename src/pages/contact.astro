---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const contactInfo = [
	{
		icon: 'location',
		title: 'Adres',
		content: 'İkitelli OSB Mahallesi\nAtatürk Bulvarı No:127\nBaşakşehir, İstanbul 34307\nTürkiye',
	},
	{
		icon: 'phone',
		title: 'Telefon',
		content: '+90 212 549 0000\n+90 532 000 0000',
	},
	{
		icon: 'email',
		title: 'E-posta',
		content: 'info@ecpower.com.tr\nsales@ecpower.com.tr\nsupport@ecpower.com.tr',
	},
	{
		icon: 'hours',
		title: 'Çalışma Saatleri',
		content: 'Pazartesi - Cuma: 09:00 - 18:00\nCumartesi: 10:00 - 14:00',
	},
];

const faqs = [
	{
		q: 'EC POWER ürünleri için garanti süresi nedir?',
		a: 'Tüm EC POWER ürünleri 2-3 yıl arası garanti süresi ile sunulmaktadır. Detaylı bilgi için ürün sayfalarını inceleyebilirsiniz.',
	},
	{
		q: 'Özel voltaj değerlerinde üretim yapıyor musunuz?',
		a: 'Evet, standart dışı voltaj ve akım gereksinimleriniz için özel tasarım çözümleri sunuyoruz. İletişime geçerek ihtiyaçlarınızı paylaşabilirsiniz.',
	},
	{
		q: 'Uluslararası gönderim yapıyor musunuz?',
		a: "Evet, 30'dan fazla ülkeye gönderim yapıyoruz. Kargo maliyetleri ve teslimat süreleri hakkında bilgi almak için satış ekibimizle iletişime geçin.",
	},
	{
		q: 'Teknik destek hizmetleriniz nelerdir?',
		a: '7/24 teknik destek hizmeti sunuyoruz. Kurulum, devreye alma ve arıza durumlarında uzman ekibimiz yanınızda.',
	},
];
---

<Layout 
  title="İletişim" 
  description="EC POWER ile iletişime geçin. Lazer epilasyon power supply çözümleri için teklif alın. İstanbul İkitelli OSB'de 7/24 teknik destek."
  breadcrumbs={[
    { name: 'Ana Sayfa', url: 'https://ecpower.com.tr/' },
    { name: 'İletişim', url: 'https://ecpower.com.tr/contact' }
  ]}
  faqs={[
    { q: 'EC POWER ürünleri için garanti süresi nedir?', a: 'Tüm EC POWER ürünleri 2-3 yıl arası garanti süresi ile sunulmaktadır. Detaylı bilgi için ürün sayfalarını inceleyebilirsiniz.' },
    { q: 'Özel voltaj değerlerinde üretim yapıyor musunuz?', a: 'Evet, standart dışı voltaj ve akım gereksinimleriniz için özel tasarım çözümleri sunuyoruz. İletişime geçerek ihtiyaçlarınızı paylaşabilirsiniz.' },
    { q: 'Uluslararası gönderim yapıyor musunuz?', a: "Evet, 30'dan fazla ülkeye gönderim yapıyoruz. Kargo maliyetleri ve teslimat süreleri hakkında bilgi almak için satış ekibimizle iletişime geçin." },
    { q: 'Teknik destek hizmetleriniz nelerdir?', a: '7/24 teknik destek hizmeti sunuyoruz. Kurulum, devreye alma ve arıza durumlarında uzman ekibimiz yanınızda.' },
  ]}
>
  <a href="#main-content" class="skip-link">Ana içeriğe geç</a>
  <Navbar />

  <main id="main-content">
		<section class="page-hero">
			<div class="container">
				<span class="section-tag">İletişim</span>
				<h1>
					Bizimle <span class="gradient-text">İletişime Geçin</span>
				</h1>
				<p>
					Projeniz için en uygun power supply çözümünü bulmak veya herhangi bir soru sormak için
					uzman ekibimizle iletişime geçin.
				</p>
			</div>
		</section>

		<section class="contact-section">
			<div class="container">
				<div class="contact-grid">
					<div class="contact-info">
						<h2>İletişim Bilgilerimiz</h2>
						<p>Ekipimiz, sorularınızı yanıtlamak ve size en iyi çözümü sunmak için hazır.</p>

						<div class="info-list">
							{contactInfo.map((info) => (
								<div class="info-item">
									<div class="info-icon">
										{info.icon === 'location' && (
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
												<circle cx="12" cy="10" r="3" />
											</svg>
										)}
										{info.icon === 'phone' && (
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
											</svg>
										)}
										{info.icon === 'email' && (
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
												<polyline points="22,6 12,13 2,6" />
											</svg>
										)}
										{info.icon === 'hours' && (
											<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
												<circle cx="12" cy="12" r="10" />
												<polyline points="12 6 12 12 16 14" />
											</svg>
										)}
									</div>
									<div class="info-content">
										<h4>{info.title}</h4>
										<pre>{info.content}</pre>
									</div>
								</div>
							))}
						</div>

						<div class="social-section">
							<h4>Bizi Takip Edin</h4>
							<div class="social-links">
								<a href="#" class="social-link" aria-label="LinkedIn">
									<svg viewBox="0 0 24 24" fill="currentColor">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
									</svg>
								</a>
								<a href="#" class="social-link" aria-label="Twitter">
									<svg viewBox="0 0 24 24" fill="currentColor">
										<path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z" />
									</svg>
								</a>
								<a href="#" class="social-link" aria-label="YouTube">
									<svg viewBox="0 0 24 24" fill="currentColor">
										<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
									</svg>
								</a>
							</div>
						</div>
					</div>

					<div class="contact-form-section">
						<div class="form-card">
							<h3>Teklif Formu</h3>
							<p>Projeniz hakkında bilgi verin, size en uygun çözümü sunalım.</p>

							<form id="contactForm" class="contact-form">
								<div class="form-row">
									<div class="form-group">
										<label for="name">Adınız Soyadınız *</label>
										<input type="text" id="name" name="name" required placeholder="Adınız Soyadınız" />
									</div>
									<div class="form-group">
										<label for="company">Şirket</label>
										<input type="text" id="company" name="company" placeholder="Şirket Adı" />
									</div>
								</div>

								<div class="form-row">
									<div class="form-group">
										<label for="email">E-posta *</label>
										<input type="email" id="email" name="email" required placeholder="ornek@email.com" />
									</div>
									<div class="form-group">
										<label for="phone">Telefon</label>
										<input type="tel" id="phone" name="phone" placeholder="+90 5XX XXX XX XX" />
									</div>
								</div>

								<div class="form-group">
									<label for="product">İlgilendiğiniz Ürün</label>
									<select id="product" name="product">
										<option value="">Ürün Seçiniz</option>
										<option value="EC-500">EC-500 Power Supply</option>
										<option value="EC-800">EC-800 Power Supply</option>
										<option value="EC-1200">EC-1200 Power Supply</option>
										<option value="EC-2000">EC-2000 Power Supply</option>
										<option value="custom">Özel Çözüm / Tasarım</option>
									</select>
								</div>

								<div class="form-group">
									<label for="message">Mesajınız *</label>
									<textarea
										id="message"
										name="message"
										rows="5"
										required
										placeholder="Projeniz veya ihtiyaçlarınız hakkında detaylı bilgi verin..."
									></textarea>
								</div>

								<button type="submit" class="btn btn-primary btn-lg form-submit">
									<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
										<line x1="22" y1="2" x2="11" y2="13" />
										<polygon points="22 2 15 22 11 13 2 9 22 2" />
									</svg>
									Mesaj Gönder
								</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="faq-section" id="faq">
			<div class="container">
				<div class="section-header">
					<span class="section-tag">SSS</span>
					<h2 class="section-title">Sıkça Sorulan Sorular</h2>
				</div>

				<div class="faq-list">
					{faqs.map((faq) => (
						<div class="faq-item">
							<button class="faq-question" type="button">
								<span>{faq.q}</span>
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="6 9 12 15 18 9" />
								</svg>
							</button>
							<div class="faq-answer">
								<p>{faq.a}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
.page-hero {
	/* global Layout'taki .page-hero ile uyumlu */
	background: var(--bg-light);
}

.page-hero h1 {
	font-size: clamp(40px, 6vw, 56px);
	margin: 16px 0 24px;
	color: var(--text-primary);
}

.page-hero p {
	font-size: 18px;
	color: var(--text-secondary);
	max-width: 600px;
	line-height: 1.7;
}

.contact-section {
	padding: 100px 0;
	background: var(--bg-white);
}

.contact-grid {
	display: grid;
	grid-template-columns: 1fr 1.2fr;
	gap: 80px;
}

.contact-info h2 {
	font-size: 28px;
	color: var(--text-primary);
	margin-bottom: 12px;
}

.contact-info > p {
	color: var(--text-secondary);
	font-size: 16px;
	margin-bottom: 40px;
}

.info-list {
	display: flex;
	flex-direction: column;
	gap: 24px;
	margin-bottom: 40px;
}

.info-item {
	display: flex;
	gap: 20px;
	padding: 24px;
	background: var(--bg-light);
	border: 1px solid var(--border-light);
	border-radius: 16px;
	transition: all 0.3s;
}

.info-item:hover {
	border-color: rgba(37, 99, 235, 0.35);
	box-shadow: var(--shadow-sm);
}

.info-icon {
	width: 56px;
	height: 56px;
	background: var(--gradient-primary);
	border-radius: 14px;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

.info-icon svg {
	width: 24px;
	height: 24px;
	color: white;
}

.info-content h4 {
	font-size: 18px;
	color: var(--text-primary);
	margin-bottom: 8px;
}

.info-content pre {
	font-family: inherit;
	font-size: 14px;
	color: var(--text-secondary);
	white-space: pre-line;
	line-height: 1.6;
}

.social-section h4 {
	font-size: 16px;
	color: var(--text-primary);
	margin-bottom: 16px;
}

.social-links {
	display: flex;
	gap: 12px;
}

.social-link {
	width: 48px;
	height: 48px;
	background: var(--bg-light);
	border: 1px solid var(--border-light);
	border-radius: 12px;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.3s;
}

.social-link:hover {
	background: var(--primary);
	border-color: var(--primary);
	transform: translateY(-3px);
}

.social-link svg {
	width: 22px;
	height: 22px;
	color: var(--text-secondary);
	transition: color 0.3s;
}

.social-link:hover svg {
	color: white;
}

.form-card {
	background: var(--bg-white);
	border: 1px solid var(--border-light);
	border-radius: 24px;
	padding: 50px;
	box-shadow: var(--shadow-lg);
}

.form-card h3 {
	font-size: 26px;
	color: var(--text-primary);
	margin-bottom: 10px;
}

.form-card > p {
	color: var(--text-secondary);
	font-size: 15px;
	margin-bottom: 30px;
}

.contact-form {
	display: flex;
	flex-direction: column;
	gap: 20px;
}

.form-row {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 20px;
}

.form-group {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.form-group label {
	font-size: 14px;
	font-weight: 500;
	color: var(--text-secondary);
}

.form-group input,
.form-group select,
.form-group textarea {
	padding: 16px 20px;
	background: var(--bg-light);
	border: 1px solid var(--border-light);
	border-radius: 12px;
	font-size: 15px;
	font-family: inherit;
	color: var(--text-primary);
	transition: all 0.3s;
}

.form-group select {
	cursor: pointer;
}

.form-submit {
	margin-top: 10px;
}

.faq-section {
	padding: 100px 0;
	background: var(--bg-light);
}

.section-header {
	text-align: center;
	max-width: 700px;
	margin: 0 auto 60px;
}

.faq-list {
	max-width: 800px;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	gap: 16px;
}

.faq-item {
	background: var(--bg-white);
	border: 1px solid var(--border-light);
	border-radius: 16px;
	overflow: hidden;
	transition: all 0.3s;
}

.faq-item:hover {
	border-color: rgba(37, 99, 235, 0.35);
}

.faq-question {
	width: 100%;
	padding: 24px 30px;
	background: none;
	border: none;
	display: flex;
	justify-content: space-between;
	align-items: center;
	cursor: pointer;
	text-align: left;
}

.faq-question span {
	font-size: 17px;
	font-weight: 600;
	color: var(--text-primary);
}

.faq-question svg {
	width: 24px;
	height: 24px;
	color: var(--text-secondary);
	transition: transform 0.3s;
	flex-shrink: 0;
}

.faq-item.active .faq-question svg {
	transform: rotate(180deg);
}

.faq-answer {
	max-height: 0;
	overflow: hidden;
	transition: max-height 0.3s ease;
}

.faq-item.active .faq-answer {
	max-height: 260px;
}

.faq-answer p {
	padding: 0 30px 24px;
	font-size: 15px;
	color: var(--text-secondary);
	line-height: 1.7;
}

@media (max-width: 1024px) {
	.contact-grid {
		grid-template-columns: 1fr;
	}

	.form-row {
		grid-template-columns: 1fr;
	}
}
</style>

<script>
document.querySelectorAll('.faq-item').forEach((item) => {
	const question = item.querySelector('.faq-question');
	question?.addEventListener('click', () => {
		document.querySelectorAll('.faq-item').forEach((i) => {
			if (i !== item) i.classList.remove('active');
		});
		item.classList.toggle('active');
	});
});

document.getElementById('contactForm')?.addEventListener('submit', function (e) {
	e.preventDefault();
	alert('Mesajınız başarıyla gönderildi! En kısa sürede size dönüş yapacağız.');
	// @ts-ignore
	this.reset();
});
</script>

