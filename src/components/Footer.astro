---
const footerLinks = {
	products: [
		{ label: 'EC-500 Power Supply', href: '/products#ec500' },
		{ label: 'EC-800 Power Supply', href: '/products#ec800' },
		{ label: 'EC-1200 Power Supply', href: '/products#ec1200' },
		{ label: 'Özel Çözümler', href: '/contact' },
	],
	company: [
		{ label: 'Hakkımızda', href: '/about' },
		{ label: 'Kariyer', href: '#' },
		{ label: 'Blog', href: '#' },
		{ label: 'Basın', href: '#' },
	],
	support: [
		{ label: 'Teknik Dökümanlar', href: '#' },
		{ label: 'Garanti Koşulları', href: '#' },
		{ label: 'Sıkça Sorulanlar', href: '/contact#faq' },
		{ label: 'Destek Talebi', href: '/contact' },
	]
};
---

<footer class="footer" role="contentinfo" aria-label="Site footer">
	<div class="footer-gradient"></div>
	<div class="container">
		<div class="footer-grid">
			<div class="footer-brand">
				<a href="/" class="footer-logo">
					<svg viewBox="0 0 60 60" width="48" height="48">
						<defs>
							<linearGradient id="footerGrad" x1="0%" y1="0%" x2="100%" y2="100%">
								<stop offset="0%" style="stop-color:#2563EB"/>
								<stop offset="100%" style="stop-color:#06B6D4"/>
							</linearGradient>
						</defs>
						<rect width="60" height="60" rx="14" fill="url(#footerGrad)"/>
						<text x="30" y="38" font-family="Arial, sans-serif" font-size="22" font-weight="bold" fill="white" text-anchor="middle">EC</text>
					</svg>
					<div class="footer-brand-text">
						<span class="brand">EC</span>
						<span class="power">POWER</span>
					</div>
				</a>
				<p class="footer-desc">Lazer epilasyon cihazları için yüksek performanslı güç kaynakları. 15 yılı aşkın deneyim ile profesyonel çözümler.</p>
				<div class="social-links">
					<a href="#" class="social-link" aria-label="LinkedIn">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
					</a>
					<a href="#" class="social-link" aria-label="Twitter">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
						</svg>
					</a>
					<a href="#" class="social-link" aria-label="YouTube">
						<svg viewBox="0 0 24 24" fill="currentColor">
							<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
						</svg>
					</a>
				</div>
			</div>

			<div class="footer-links">
				<div class="footer-col">
					<h4>Ürünler</h4>
					{footerLinks.products.map(link => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
				<div class="footer-col">
					<h4>Şirket</h4>
					{footerLinks.company.map(link => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
				<div class="footer-col">
					<h4>Destek</h4>
					{footerLinks.support.map(link => (
						<a href={link.href}>{link.label}</a>
					))}
				</div>
			</div>
		</div>

		<div class="footer-bottom">
			<div class="footer-contact">
				<div class="contact-item">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
					</svg>
					<span>İkitelli OSB, İstanbul, Türkiye</span>
				</div>
				<div class="contact-item">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
					</svg>
					<span>+90 212 549 0000</span>
				</div>
				<div class="contact-item">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
					</svg>
					<span>info@ecpower.com.tr</span>
				</div>
			</div>
			<p>&copy; 2026 EC POWER. Tüm hakları saklıdır.</p>
		</div>
	</div>
</footer>

<style>
.footer {
	position: relative;
	background: var(--dark);
	color: white;
	padding: 100px 0 40px;
	overflow: hidden;
}

.footer-gradient {
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	height: 1px;
	background: linear-gradient(90deg, transparent, var(--primary), var(--accent), transparent);
}

.footer-grid {
	display: grid;
	grid-template-columns: 1.5fr 2fr;
	gap: 80px;
	margin-bottom: 80px;
}

.footer-logo {
	display: flex;
	align-items: center;
	gap: 14px;
	text-decoration: none;
	margin-bottom: 24px;
}

.footer-brand-text {
	display: flex;
	flex-direction: column;
	line-height: 1.1;
}

.footer-brand-text .brand {
	font-family: 'Space Grotesk', sans-serif;
	font-size: 22px;
	font-weight: 700;
	color: white;
	letter-spacing: -0.02em;
}

.footer-brand-text .power {
	font-size: 11px;
	font-weight: 600;
	color: var(--accent);
	letter-spacing: 3px;
	text-transform: uppercase;
}

.footer-desc {
	color: var(--text-muted);
	font-size: 15px;
	line-height: 1.7;
	max-width: 320px;
	margin-bottom: 32px;
}

.social-links {
	display: flex;
	gap: 12px;
}

.social-link {
	width: 44px;
	height: 44px;
	background: rgba(255, 255, 255, 0.05);
	border: 1px solid rgba(255, 255, 255, 0.1);
	border-radius: 12px;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: all 0.3s;
}

.social-link:hover {
	background: var(--primary);
	border-color: var(--primary);
	transform: translateY(-3px);
}

.social-link svg {
	width: 20px;
	height: 20px;
	color: var(--text-muted);
	transition: color 0.3s;
}

.social-link:hover svg {
	color: white;
}

.footer-links {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 40px;
}

.footer-col h4 {
	font-size: 15px;
	font-weight: 600;
	color: white;
	margin-bottom: 24px;
	font-family: 'Space Grotesk', sans-serif;
	letter-spacing: 0.5px;
}

.footer-col a {
	display: block;
	color: var(--text-muted);
	text-decoration: none;
	font-size: 14px;
	margin-bottom: 14px;
	transition: all 0.3s;
}

.footer-col a:hover {
	color: var(--accent);
	transform: translateX(5px);
}

.footer-bottom {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding-top: 40px;
	border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.footer-contact {
	display: flex;
	gap: 32px;
}

.contact-item {
	display: flex;
	align-items: center;
	gap: 10px;
	font-size: 14px;
	color: var(--text-muted);
}

.contact-item svg {
	width: 18px;
	height: 18px;
	color: var(--accent);
}

.footer-bottom p {
	color: var(--text-muted);
	font-size: 14px;
}

@media (max-width: 1024px) {
	.footer-grid {
		grid-template-columns: 1fr;
		gap: 50px;
	}

	.footer-links {
		grid-template-columns: repeat(3, 1fr);
	}
}

@media (max-width: 768px) {
	.footer-links {
		grid-template-columns: 1fr;
	}

	.footer-bottom {
		flex-direction: column;
		gap: 24px;
		text-align: center;
	}

	.footer-contact {
		flex-direction: column;
		gap: 16px;
	}
}
</style>