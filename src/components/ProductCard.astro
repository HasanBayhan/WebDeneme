---
interface Props {
	name: string;
	model: string;
	power: string;
	voltage: string;
	current: string;
	efficiency: string;
	features: string[];
	certifications: string[];
	badge?: string;
	index: number;
}

const { name, model, power, voltage, current, efficiency, features, certifications, badge, index } = Astro.props;
---

<article class="product-card" data-index={index}>
	{badge && (
		<div class="card-badge">
			<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
				<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
			</svg>
			{badge}
		</div>
	)}

	<div class="card-header">
		<div class="model-badge">{model}</div>
		<h3 class="product-name">{name}</h3>
	</div>

	<div class="product-visual">
		<div class="psu-render">
			<div class="psu-body">
				<div class="psu-front">
					<div class="psu-label">{model}</div>
					<div class="psu-leds">
						<div class="led green"></div>
						<div class="led blue"></div>
					</div>
					<div class="psu-vents">
						<div class="vent-line"></div>
						<div class="vent-line"></div>
						<div class="vent-line"></div>
					</div>
				</div>
				<div class="psu-fan">
					<div class="fan-blade"></div>
					<div class="fan-blade"></div>
					<div class="fan-blade"></div>
					<div class="fan-blade"></div>
				</div>
				<div class="psu-screws">
					<div class="screw"></div>
					<div class="screw"></div>
					<div class="screw"></div>
					<div class="screw"></div>
				</div>
			</div>
			<div class="energy-field">
				<div class="wave wave-1"></div>
				<div class="wave wave-2"></div>
				<div class="wave wave-3"></div>
			</div>
		</div>
	</div>

	<div class="specs-grid">
		<div class="spec-item">
			<div class="spec-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
				</svg>
			</div>
			<div class="spec-content">
				<span class="spec-label">Güç</span>
				<span class="spec-value">{power}</span>
			</div>
		</div>
		<div class="spec-item">
			<div class="spec-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
				</svg>
			</div>
			<div class="spec-content">
				<span class="spec-label">Voltaj</span>
				<span class="spec-value">{voltage}</span>
			</div>
		</div>
		<div class="spec-item">
			<div class="spec-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="12" cy="12" r="10"/>
					<polyline points="12 6 12 12 16 14"/>
				</svg>
			</div>
			<div class="spec-content">
				<span class="spec-label">Akım</span>
				<span class="spec-value">{current}</span>
			</div>
		</div>
		<div class="spec-item">
			<div class="spec-icon">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
					<polyline points="22 4 12 14.01 9 11.01"/>
				</svg>
			</div>
			<div class="spec-content">
				<span class="spec-label">Verimlilik</span>
				<span class="spec-value">{efficiency}</span>
			</div>
		</div>
	</div>

	<div class="features-list">
		{features.slice(0, 4).map(feature => (
			<span class="feature-tag">
				<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
					<polyline points="20 6 9 17 4 12"/>
				</svg>
				{feature}
			</span>
		))}
	</div>

	<div class="certifications">
		{certifications.map(cert => (
			<span class="cert-badge">{cert}</span>
		))}
	</div>

	<div class="card-actions">
		<a href="/contact" class="btn btn-primary">
			<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
				<polyline points="22,6 12,13 2,6"/>
			</svg>
			Detay & Teklif
		</a>
		<button class="btn btn-outline" data-product={model}>
			<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
				<circle cx="11" cy="11" r="8"/>
				<line x1="21" y1="21" x2="16.65" y2="16.65"/>
			</svg>
			Karşılaştır
		</button>
	</div>
</article>

<style>
.product-card {
	position: relative;
	background: white;
	border: 1px solid var(--border-light);
	border-radius: 24px;
	padding: 40px;
	transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	overflow: hidden;
	box-shadow: var(--shadow-sm);
}

.product-card:hover {
	transform: translateY(-8px);
	border-color: rgba(37, 99, 235, 0.3);
	box-shadow: var(--shadow-xl), 0 0 0 1px rgba(37, 99, 235, 0.1);
}

.card-badge {
	position: absolute;
	top: 24px;
	right: 24px;
	display: flex;
	align-items: center;
	gap: 6px;
	padding: 8px 14px;
	background: var(--gradient-primary);
	border-radius: 100px;
	font-size: 12px;
	font-weight: 600;
	color: white;
	box-shadow: var(--shadow-blue);
}

.card-header {
	margin-bottom: 30px;
}

.model-badge {
	display: inline-block;
	padding: 6px 12px;
	background: linear-gradient(135deg, rgba(37, 99, 235, 0.08) 0%, rgba(6, 182, 212, 0.08) 100%);
	border: 1px solid rgba(37, 99, 235, 0.15);
	border-radius: 8px;
	font-size: 12px;
	font-weight: 600;
	color: var(--primary);
	letter-spacing: 1px;
	margin-bottom: 12px;
}

.product-name {
	font-size: 28px;
	font-weight: 700;
	color: var(--text-primary);
	line-height: 1.2;
	letter-spacing: -0.02em;
}

.product-visual {
	margin: 30px 0;
}

.psu-render {
	position: relative;
	display: flex;
	justify-content: center;
	align-items: center;
	padding: 30px;
}

.psu-body {
	position: relative;
	width: 200px;
	height: 80px;
	background: linear-gradient(180deg, #374151 0%, #1F2937 100%);
	border-radius: 8px;
	transform: perspective(500px) rotateX(10deg);
	transition: transform 0.4s;
	box-shadow: 
		0 20px 40px rgba(0, 0, 0, 0.2),
		inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.product-card:hover .psu-body {
	transform: perspective(500px) rotateX(5deg) translateY(-5px);
}

.psu-front {
	position: absolute;
	top: 0;
	left: 0;
	right: 0;
	height: 100%;
	padding: 10px 15px;
	display: flex;
	align-items: center;
	justify-content: space-between;
}

.psu-label {
	font-size: 14px;
	font-weight: 700;
	color: var(--accent);
	font-family: 'Space Grotesk', monospace;
}

.psu-leds {
	display: flex;
	gap: 8px;
}

.led {
	width: 8px;
	height: 8px;
	border-radius: 50%;
}

.led.green {
	background: #10B981;
	box-shadow: 0 0 15px rgba(16, 185, 129, 0.8);
}

.led.blue {
	background: var(--accent);
	box-shadow: 0 0 15px rgba(6, 182, 212, 0.8);
	animation: blink 2s infinite;
}

@keyframes blink {
	0%, 100% { opacity: 1; }
	50% { opacity: 0.5; }
}

.psu-vents {
	display: flex;
	gap: 4px;
}

.vent-line {
	width: 6px;
	height: 50px;
	background: #111;
	border-radius: 2px;
}

.psu-fan {
	position: absolute;
	right: 10px;
	top: 50%;
	transform: translateY(-50%);
	width: 50px;
	height: 50px;
	background: radial-gradient(circle, #1F2937 60%, transparent 70%);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.fan-blade {
	position: absolute;
	width: 40px;
	height: 4px;
	background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
	border-radius: 2px;
}

.fan-blade:nth-child(1) { transform: rotate(0deg); }
.fan-blade:nth-child(2) { transform: rotate(45deg); }
.fan-blade:nth-child(3) { transform: rotate(90deg); }
.fan-blade:nth-child(4) { transform: rotate(135deg); }

.psu-screws {
	position: absolute;
	bottom: -5px;
	left: 0;
	right: 0;
	display: flex;
	justify-content: space-around;
	padding: 0 20px;
}

.screw {
	width: 10px;
	height: 10px;
	background: linear-gradient(135deg, #6B7280 0%, #4B5563 100%);
	border-radius: 50%;
	border: 1px solid #9CA3AF;
}

.energy-field {
	position: absolute;
	inset: 0;
	pointer-events: none;
}

.wave {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	border: 1px solid rgba(37, 99, 235, 0.2);
	border-radius: 8px;
	opacity: 0;
}

.product-card:hover .wave {
	animation: ripple 2s infinite;
}

.wave-1 { width: 220px; height: 100px; animation-delay: 0s; }
.wave-2 { width: 260px; height: 120px; animation-delay: 0.5s; }
.wave-3 { width: 300px; height: 140px; animation-delay: 1s; }

@keyframes ripple {
	0% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
	100% { opacity: 0; transform: translate(-50%, -50%) scale(1.3); }
}

.specs-grid {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 16px;
	margin-bottom: 30px;
}

.spec-item {
	display: flex;
	align-items: center;
	gap: 12px;
	padding: 16px;
	background: var(--bg-light);
	border-radius: 12px;
	border: 1px solid var(--border-lighter);
	transition: all 0.3s;
}

.spec-item:hover {
	background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);
	border-color: rgba(37, 99, 235, 0.2);
}

.spec-icon {
	width: 36px;
	height: 36px;
	background: linear-gradient(135deg, rgba(37, 99, 235, 0.1) 0%, rgba(6, 182, 212, 0.1) 100%);
	border-radius: 10px;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}

.spec-icon svg {
	width: 18px;
	height: 18px;
	color: var(--primary);
}

.spec-content {
	display: flex;
	flex-direction: column;
}

.spec-label {
	font-size: 11px;
	color: var(--text-muted);
	text-transform: uppercase;
	letter-spacing: 1px;
}

.spec-value {
	font-size: 16px;
	font-weight: 700;
	color: var(--text-primary);
	font-family: 'Space Grotesk', sans-serif;
}

.features-list {
	display: flex;
	flex-wrap: wrap;
	gap: 10px;
	margin-bottom: 24px;
}

.feature-tag {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	padding: 8px 12px;
	background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(6, 182, 212, 0.08) 100%);
	border: 1px solid rgba(16, 185, 129, 0.15);
	border-radius: 8px;
	font-size: 13px;
	color: #059669;
}

.feature-tag svg {
	color: #059669;
}

.certifications {
	display: flex;
	flex-wrap: wrap;
	gap: 8px;
	margin-bottom: 30px;
}

.cert-badge {
	padding: 6px 10px;
	background: var(--bg-subtle);
	border: 1px solid var(--border-light);
	border-radius: 6px;
	font-size: 11px;
	font-weight: 600;
	color: var(--text-secondary);
	text-transform: uppercase;
	letter-spacing: 0.5px;
}

.card-actions {
	display: flex;
	gap: 12px;
}

.card-actions .btn {
	flex: 1;
	padding: 14px 20px;
}

@media (max-width: 768px) {
	.product-card {
		padding: 24px;
	}

	.specs-grid {
		grid-template-columns: 1fr;
	}

	.card-actions {
		flex-direction: column;
	}
}
</style>