---
import {
  generateOrganizationSchema,
  generateWebsiteSchema,
  generateBreadcrumbSchema,
  generateProductSchema,
  generateContactSchema,
  generateFAQSchema,
  generateCanonicalUrl,
  getSEOConfig,
} from '../utils/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
  breadcrumbs?: { name: string; url: string }[];
  productData?: {
    name: string;
    model: string;
    sku: string;
    description: string;
    image: string;
    brand: string;
    manufacturer: string;
    power: string;
    voltage: string;
    efficiency: string;
    price?: string;
    currency?: string;
    availability?: 'InStock' | 'OutOfStock' | 'PreOrder';
  };
  faqs?: { q: string; a: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  section,
  tags,
  breadcrumbs,
  productData,
  faqs,
  noindex = false,
} = Astro.props;

const config = getSEOConfig();
const pageUrl = generateCanonicalUrl(Astro.url.pathname);
const canonicalUrl = canonical || pageUrl;
const ogImage = image || config.defaultImage;
const fullTitle = `${title} | ${config.siteName}`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author || config.siteName} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<link rel="canonical" href={canonicalUrl} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/favicon.svg" />

<meta name="theme-color" content="#2563EB" />
<meta name="color-scheme" content="light" />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={config.siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={config.locale} />
<meta property="og:locale:alternate" content={config.localeAlternate} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && <meta property="article:author" content={author} />}
{section && <meta property="article:section" content={section} />}
{tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={config.twitterHandle} />
<meta name="twitter:creator" content={config.twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:url" content={canonicalUrl} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
<link rel="dns-prefetch" href="https://fonts.gstatic.com" />

{(type === 'website') && (
  <Fragment set:html={`<script type="application/ld+json">${generateOrganizationSchema()}</script>`} />
  <Fragment set:html={`<script type="application/ld+json">${generateWebsiteSchema()}</script>`} />
)}

{breadcrumbs && breadcrumbs.length > 0 && (
  <Fragment set:html={`<script type="application/ld+json">${generateBreadcrumbSchema(breadcrumbs)}</script>`} />
)}

{productData && (
  <Fragment set:html={`<script type="application/ld+json">${generateProductSchema({ ...productData, url: canonicalUrl })}</script>`} />
)}

{(type === 'website' && Astro.url.pathname === '/contact') && (
  <Fragment set:html={`<script type="application/ld+json">${generateContactSchema()}</script>`} />
)}

{faqs && faqs.length > 0 && (
  <Fragment set:html={`<script type="application/ld+json">${generateFAQSchema(faqs)}</script>`} />
)}