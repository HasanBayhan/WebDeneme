---
import {
  generateOrganizationSchema,
  generateWebsiteSchema,
  generateBreadcrumbSchema,
  generateProductSchema,
  generateContactSchema,
  generateFAQSchema,
  generateLocalBusinessSchema,
  generateWebPageSchema,
  generateCanonicalUrl,
  generateHreflangLinks,
  getPageKeywords,
  getSEOConfig,
} from '../utils/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article' | 'product';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
  keywords?: string;
  breadcrumbs?: { name: string; url: string }[];
  productData?: {
    name: string;
    model: string;
    sku: string;
    description: string;
    image: string;
    brand: string;
    manufacturer: string;
    power: string;
    voltage: string;
    efficiency: string;
    price?: string;
    currency?: string;
    availability?: 'InStock' | 'OutOfStock' | 'PreOrder';
  };
  faqs?: { q: string; a: string }[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  type = 'website',
  publishedTime,
  modifiedTime,
  author,
  section,
  tags,
  keywords,
  breadcrumbs,
  productData,
  faqs,
  noindex = false,
} = Astro.props;

const config = getSEOConfig();
const pageUrl = generateCanonicalUrl(Astro.url.pathname);
const canonicalUrl = canonical || pageUrl;
const ogImage = image || config.defaultImage;
const ogImageAlt = imageAlt || title;
const fullTitle = `${title} | ${config.siteName}`;
const pageKeywords = keywords || getPageKeywords(Astro.url.pathname);
const hreflangLinks = generateHreflangLinks(Astro.url.pathname);
const currentModified = modifiedTime || new Date().toISOString().split('T')[0];
const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '';
const isContactPage = Astro.url.pathname === '/contact';

const webPageSchema = generateWebPageSchema({
  name: fullTitle,
  description,
  url: canonicalUrl,
  breadcrumbs,
});

const homepageSchemas = isHomePage
  ? [
      generateOrganizationSchema(),
      generateWebsiteSchema(),
      generateLocalBusinessSchema(),
    ]
  : [];
---

<!-- Primary Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content={pageKeywords} />
<meta name="author" content={author || config.siteName} />
<meta name="copyright" content={`© ${new Date().getFullYear()} ${config.siteName}`} />
<meta name="language" content="Turkish" />
<meta name="revisit-after" content="7 days" />

{noindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <>
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="bingbot" content="index, follow" />
  </>
)}

<!-- Canonical & Hreflang -->
<link rel="canonical" href={canonicalUrl} />
{hreflangLinks.map(({ lang, url }) => (
  <link rel="alternate" hreflang={lang} href={url} />
))}

<!-- Favicons & Touch Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Theme & PWA -->
<meta name="theme-color" content="#2563EB" />
<meta name="msapplication-TileColor" content="#2563EB" />
<meta name="color-scheme" content="light" />
<meta name="application-name" content="EC POWER" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content="EC POWER" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="format-detection" content="telephone=yes" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={config.siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:image:type" content="image/png" />
<meta property="og:locale" content={config.locale} />
<meta property="og:locale:alternate" content={config.localeAlternate} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{type === 'article' && currentModified && <meta property="article:modified_time" content={currentModified} />}
{author && <meta property="article:author" content={author} />}
{section && <meta property="article:section" content={section} />}
{tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={config.twitterHandle} />
<meta name="twitter:creator" content={config.twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<meta name="twitter:url" content={canonicalUrl} />

<!-- Geo & Business -->
<meta name="geo.region" content="TR-34" />
<meta name="geo.placename" content="İstanbul, Türkiye" />
<meta name="geo.position" content="41.0604;28.7981" />
<meta name="ICBM" content="41.0604, 28.7981" />
<meta name="DC.title" content={fullTitle} />
<meta name="DC.description" content={description} />
<meta name="DC.language" content="tr" />
<meta name="DC.publisher" content="EC POWER" />

<!-- Resource Hints -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
<link rel="dns-prefetch" href="https://fonts.gstatic.com" />

<!-- Structured Data: WebPage (every page) -->
<script type="application/ld+json" set:html={webPageSchema} />

<!-- Structured Data: Organization + Website + LocalBusiness (home page only) -->
{homepageSchemas.map((schema) => (
  <script type="application/ld+json" set:html={schema} />
))}

<!-- Structured Data: Breadcrumb -->
{breadcrumbs && breadcrumbs.length > 0 && (
  <script type="application/ld+json" set:html={generateBreadcrumbSchema(breadcrumbs)} />
)}

<!-- Structured Data: Product -->
{productData && (
  <script
    type="application/ld+json"
    set:html={generateProductSchema({ ...productData, url: canonicalUrl })}
  />
)}

<!-- Structured Data: Contact Page -->
{isContactPage && (
  <script type="application/ld+json" set:html={generateContactSchema()} />
)}

<!-- Structured Data: FAQ -->
{faqs && faqs.length > 0 && (
  <script type="application/ld+json" set:html={generateFAQSchema(faqs)} />
)}
